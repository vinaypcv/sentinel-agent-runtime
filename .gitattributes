# Normalize text files in repo
* text=auto

# Keep Python/project files as LF
*.py text eol=lf
*.toml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.md text eol=lf
*.json text eol=lf
*.jsonl text eol=lf
*.txt text eol=lf
*.env.example text eol=lf
.gitignore text eol=lf

# PowerShell scripts can use CRLF on Windows
*.ps1 text eol=crlf

# Notebooks are JSON; keep LF
*.ipynb text eol=lf

# PDFs/images/binary files
*.pdf binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.zip binary
*.pt binary
*.pth binary
*.safetensors binary